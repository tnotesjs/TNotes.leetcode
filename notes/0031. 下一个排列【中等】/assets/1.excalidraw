    {
      "id": "LhMiCijEauwxu4tm7O7Km",
      "type": "text",
      "x": 190.66128351443263,
      "y": 141.2720130447981,
      "width": 80,
      "height": 20,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
