      "updated": 1776646068585,
      "link": null,
      "locked": false,
      "text": "【大方向】\n可调整数字之间的排列，找大于 12436542 的最小值。",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "【大方向】\n可调整数字之间的排列，找大于 12436542 的最小值。",
      "autoResize": true,
      "lineHeight": 1.25
    },
