      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "3WzHQZ-X56gImj2zEw7y0",
      "originalText": "因为找的是“最小值”\n查找方向：低位 -> 高位",
      "autoResize": true,
