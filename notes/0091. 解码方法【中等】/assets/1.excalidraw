    {
      "id": "VJZ2TFrfoQnWWJAqQzeLn",
      "type": "text",
      "x": -136.66978952809393,
      "y": 285.00299749028,
      "width": 478.8399658203125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
