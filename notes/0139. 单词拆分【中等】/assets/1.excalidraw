      "boundElements": [],
      "updated": 1783843127532,
      "link": null,
      "locked": false,
      "text": "虽然 dog 位于 wordDict 中\n但由于 dp[6] ≠ true\n因此 dp[9] 不能设为 true",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "虽然 dog 位于 wordDict 中\n但由于 dp[6] ≠ true\n因此 dp[9] 不能设为 true",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Jqul-_x2aTkFv1D6SPPXl",
      "type": "text",
      "x": -421.70961179019264,
      "y": -318.9745726884091,
      "width": 154.55999755859375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
