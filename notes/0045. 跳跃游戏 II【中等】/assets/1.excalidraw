    {
      "id": "biC405g2xRLpi3hTez7N7",
      "type": "text",
      "x": 20.278391287364684,
      "y": 436.3385629036875,
      "width": 284.927978515625,
      "height": 60,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
