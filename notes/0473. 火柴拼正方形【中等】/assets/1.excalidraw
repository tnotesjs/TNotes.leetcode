    {
      "id": "QMq1KnXVOzhb6HR9Pt2GG",
      "type": "text",
      "x": 556.2477805000005,
      "y": 1350.0078105000002,
      "width": 712.0999145507812,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
