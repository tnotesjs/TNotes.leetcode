      "link": null,
      "locked": false,
      "text": "根据 left 的值初始化 prev 的指向\nprev.next 指向的是反转的起点",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "根据 left 的值初始化 prev 的指向\nprev.next 指向的是反转的起点",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
